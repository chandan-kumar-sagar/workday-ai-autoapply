{
  "manifest_version": 3,

  "name": "Workday AI Auto Apply",

  "version": "1.0.0",

  "description": "AI-powered Workday autofill extension",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "http://localhost:5000/*",
    "http://*/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],

      "js": [
        "content/contentScript.js"
      ],

      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html"
  }
}